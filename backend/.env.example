# ── Store identity ────────────────────────────────────
STORE_NAME=My Retail Store
STORE_LAT=-33.8688       # Sydney default — change to your coordinates
STORE_LON=151.2093
STORE_TIMEZONE=Australia/Sydney
STORE_STATE=NSW          # For Australian public holiday detection (NSW/VIC/QLD/WA/SA/TAS/ACT/NT)

# ── API keys ──────────────────────────────────────────
GOOGLE_VISION_API_KEY=your-google-vision-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Camera config ─────────────────────────────────────
# Mode: webcam | rtsp | http | arlo
CAMERA_MODE=webcam
CAMERA_SOURCE=0          # webcam index, or URL for rtsp/http

# RTSP example: CAMERA_SOURCE=rtsp://admin:pass@192.168.1.100:554/stream
# HTTP example: CAMERA_SOURCE=http://192.168.1.100:8080/video
# Arlo: fill in ARLO_EMAIL + ARLO_PASSWORD below

ARLO_EMAIL=
ARLO_PASSWORD=
ARLO_DEVICE_NAME=        # Name of the Arlo camera to use

# ── Detection settings ────────────────────────────────
CAPTURE_INTERVAL=3       # seconds between frames
QUEUE_THRESHOLD=2        # people in a zone before it counts as a queue event
PASSERBY_EDGE=0.15       # bounding box within this margin of frame edge = passerby

# ── Scheduling ────────────────────────────────────────
DAY_END_TIME=18:00       # time to auto-generate daily summary (HH:MM, 24h)

# ── Flask ─────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5050
